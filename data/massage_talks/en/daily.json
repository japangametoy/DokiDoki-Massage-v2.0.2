    "talk_anime_secret": {
      "topicName": "Secret Anime Hobby",
      "trustEffect": 4,
      "developEffect": 0,
      "alertnessEffect": -4,
      "pleasureEffect": 2,
      "sleepinessEffect": 1,
      "dialogues": [
        {
          "character": "player",
          "expression": "normal_01",
          "text": "You mentioned listening to anime songs before. What anime do you like?"
