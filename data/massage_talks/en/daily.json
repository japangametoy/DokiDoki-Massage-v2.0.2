      "alertnessEffect": -1,
      "pleasureEffect": 0,
      "sleepinessEffect": 4,
      "dialogues": [
        {
          "character": "player",
          "expression": "sleepy_01",
          "text": "When you sleep, do you prefer lying on your side or on your back?"
