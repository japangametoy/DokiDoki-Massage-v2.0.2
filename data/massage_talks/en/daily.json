        {
          "character": "player",
          "expression": "sleepy_01",
          "text": "Using your phone on your side is bad for your neck."
        },
        {
          "character": "player",
          "expression": "sleepy_01",
          "text": "Try lying on your back and putting a pillow under your knees - it helps your lower back. The trick is to stop using your phone 30 minutes before bed and dim the lights."
        },
        {
          "character": "Nana",
          "expression": "sleepy_02",
          "text": "A pillow under my knees... I didn't know that. Thank you, I'll try it.",
          "voiceFile": "talk_sleep_002"
        }
      ]
    },
