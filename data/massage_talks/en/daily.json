        {
          "character": "Nana",
          "expression": "alert_02",
          "text": "Y-yes... It's childish, isn't it...",
          "voiceFile": "talk_anime_secret_003"
        },
        {
          "character": "player",
          "expression": "normal_01",
          "text": "How long have you been watching it?"
