{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──3ヶ月後。\n整体院は順調に営業していた。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "先生…こんにちは…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ナナちゃん。今週も来たんだね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "はい…その…また…お願いしたくて…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "もう、肩こりはよくなったと思うけど…まだ通ってくれるんだね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "ぅ……その…身体が…求めちゃってるんです…"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "普通のマッサージじゃ…もう…物足りないんです…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "そっか。今日もいつものコース？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…はい。お願いします。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──施術中"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "んっ…♡ああっ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "もう身体がすぐ反応するようになったね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "は、恥ずかしいです…こんなに…すぐに…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "でも気持ちいいんでしょ？"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "…はい…気持ち…いいです…"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──しばらくして"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "はぁ…はぁ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "今日もよく感じてたね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "あの……"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ん？"
    },

    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…お礼に…私も…先生にマッサージ…していいですか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "え？ナナちゃんが俺に？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "は、はい…いつも気持ちよくしてもらってるから…"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "私も…先生を…気持ちよくしたくて…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "そっか。じゃあ…お願いしようかな。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "はい…お口で…先生のを…マッサージしますね…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "え？口で？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "あんまり…うまくできるか分からないですけど…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（自分からそこまで…完全に堕ちたな…）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが恥ずかしそうに、ズボンに手を伸ばしてくる。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…失礼します…"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんは少し震える手で、整体師のちんぽを取り出した。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "ぁ…もう…こんなに…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが恥ずかしそうに、勃起した整体師のちんぽに顔を近づけた。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…んむ…"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "んっ、ふぅ…。あむ……んむっ……"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…ぷはっ…♡"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "先生…どう…でしたか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "すごく…気持ちよかったよ。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "よかったです…"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが恥ずかしそうに、でも期待した目でこちらを見つめている。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "あの…先生…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ん？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "次は……お…おまんこで、マッサージ…してもいいですか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ほぉ。ついに自分からそんなこと言うようになったんだね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "だって……身体が…疼いて…我慢できないんです…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "しょうがないな。"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "ありがとうございます…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんの身体は完全に開発され、快楽なしでは満足できなくなっていた。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "恥ずかしがりながらも、自分から求めてしまう。\nそれは信頼関係というよりも、身体が求める本能的な欲求だった。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "【DEVELOP MAX END - 開発された身体】",
      "triggerEnding": "develop_max"
    }
  ]
}
