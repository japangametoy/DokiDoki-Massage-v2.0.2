{
  "dialogues": [
    {
      "character": "",
      "hideCharacter": true,
      "text": "──3ヶ月後。\n整体院は順調に営業していた。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "",
      "playSE": "door_chime"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "先生…こんにちは…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ナナちゃん。今週も来たんだね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "はい…その…また…お願いしたくて…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "もう、肩こりはよくなったと思うけど…まだ通ってくれるんだね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "ぅ……その…身体が…求めちゃってるんです…"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "普通のマッサージじゃ…もう…物足りないんです…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "そっか。今日もいつものコース？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…はい。お願いします。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──施術中"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "んっ…♡ああっ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "もう身体がすぐ反応するようになったね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "は、恥ずかしいです…こんなに…すぐに…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "でも気持ちいいんでしょ？"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "…はい…気持ち…いいです…"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "──しばらくして"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "はぁ…はぁ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "今日もよく感じてたね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "あの……"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ん？"
    },

    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…お礼に…私も…先生にマッサージ…していいですか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "え？ナナちゃんが俺に？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "は、はい…いつも気持ちよくしてもらってるから…"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "私も…先生を…気持ちよくしたくて…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "そっか。じゃあ…お願いしようかな。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "はい…胸と…お口で…先生のを…マッサージしますね…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "おっぱいと口で？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "あんまり…うまくできるか分からないですけど……頑張ります…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（自分からそこまで…完全に堕ちたな…）"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが恥ずかしそうに、ズボンに手を伸ばしてくる。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "…失礼します…"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんは少し震える手で、整体師のちんぽを取り出した。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "ぁ…もう…こんなに…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが近くにあったマッサージローションを手に取る。"
    },
    {
      "character": "nana",
      "expression": "shy",
      "text": "あの…これ…使ってもいいですか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ああ、もちろん。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "（とろり…とローションがナナちゃんの胸の谷間に垂れていく）"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "んっ…冷たい……"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが恥ずかしそうに、自分の胸にローションを塗り広げていく。"
    },
    {
      "character": "nana",
      "expression": "shy",
      "text": "…ぬるぬるする…"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんはゆっくりと、ぬるぬると光る胸でちんぽを挟み込む。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "んっ…♡ こんな感じで…いいですか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ああ…すごく気持ちいいよ、ナナちゃん。"
    },
    {
      "character": "nana",
      "expression": "shy",
      "text": "よかった…です…。じゃあ…マッサージ…しますね…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "（ぬちゅ…ぬちゅ…とローションで濡れた柔らかい乳肉が、ちんぽを包み込む）"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "んっ…♡ れろ…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "おっぱいで挟みながら、ナナちゃんが恥ずかしそうに先端を舐め始めた。"
    },
    {
      "character": "nana",
      "expression": "shy",
      "text": "んむっ…♡ ちゅ…♡ れろれろ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ナナちゃん…すごい…"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "（ねちょねちょと卑猥な水音を立てながら、一生懸命パイズリフェラを続けるナナちゃん）"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "んぢゅっ…♡ ちゅるっ…♡ んっ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ナナちゃん、上手だよ。すごく気持ちいい。"
    },
    {
      "character": "nana",
      "expression": "shy",
      "text": "ん…ふっ…♡ 本当…ですか…？ んちゅっ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ああ、本当だよ。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "整体師がナナちゃんの頭を優しく撫でる。"
    },
    {
      "character": "nana",
      "expression": "shy",
      "text": "ふふっ…♡ 先生の手…あったかいです…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが嬉しそうに微笑みながら、さらに一生懸命に奉仕を続ける。"
    },
    {
      "character": "nana",
      "expression": "smile",
      "text": "んむっ…♡ じゅぼっ…♡ れろれろ…♡"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "（こんなに嬉しそうにしてくれて…可愛いな…）"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "ぷはっ…♡ 先生…気持ちよく…なってくれましたか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ああ、すごく気持ちよかったよ。ナナちゃん、ありがとう。"
    },
    {
      "character": "nana",
      "expression": "smile",
      "text": "えへへ…♡ よかったです…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんが恥ずかしそうに、でも期待した目でこちらを見つめている。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "あの…先生…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ん？"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "次は……お…おまんこで、マッサージ…してもいいですか…？"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "ほぉ。ついに自分からそんなこと言うようになったんだね。"
    },
    {
      "character": "nana",
      "expression": "embarrassed",
      "text": "だって……身体が…疼いて…我慢できないんです…"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "しょうがないな。"
    },
    {
      "character": "nana",
      "expression": "pleasure",
      "text": "ありがとうございます…♡"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "ナナちゃんの身体は完全に開発され、快楽なしでは満足できなくなっていた。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "恥ずかしがりながらも、自分から求めてしまう。\nそれは信頼関係というよりも、身体が求める本能的な欲求だった。"
    },
    {
      "character": "",
      "hideCharacter": true,
      "text": "【DEVELOP MAX END - 開発された身体】",
      "triggerEnding": "develop_max"
    }
  ]
}
