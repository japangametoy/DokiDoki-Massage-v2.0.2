    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "Memorized...?",
      "voiceFile": "story_day8_007"
    },
    {
      "character": "player",
      "expression": "blush_closemouth",
      "text": "Yes. The body has memory. Especially pleasurable sensations are strongly remembered."
    },
    {
      "character": "nana",
      "expression": "blush_openmouth",
      "text": "So... my body has memorized your hands, sensei...?",
