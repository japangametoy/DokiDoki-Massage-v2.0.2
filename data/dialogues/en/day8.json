    {
      "character": "",
      "hideCharacter": true,
      "text": "Morning of the 8th week.\nThrough two months of treatment, Nana's body has definitely changed."
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(8 weeks of treatment... Nana's body's responses are improving day by day.)"
