    },
    {
      "character": "player",
      "expression": "alert",
      "text": "N-no, that's not...",
      "hideCharacter": true
    },
    {
      "character": "tatsu",
      "expression": "normal",
      "text": "So? You got this month's payment ready, right?",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "id": "tatsu_choice",
      "character": "player",
      "expression": "alert",
      "text": "W-well... I need a little more time...",
