      "hideCharacter": true,
      "next": "tatsu_threat"
    },
    {
      "id": "tatsu_promise",
      "character": "player",
      "expression": "alert",
      "text": "I'll definitely pay the full amount by next week!",
      "hideCharacter": true
    },
    {
      "character": "tatsu",
      "expression": "normal",
      "text": "Next week? You think you got time to be saying that?",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "id": "tatsu_excuse",
      "character": "player",
      "expression": "alert",
      "text": "I-I'm sorry...",
      "hideCharacter": true,
      "next": "tatsu_threat"
    },
    {
      "id": "tatsu_borrow",
      "character": "player",
      "expression": "alert",
      "text": "Actually... I'd like to borrow an additional 100,000...",
      "hideCharacter": true
    },
    {
      "character": "tatsu",
      "expression": "normal",
      "text": "Huh? You can't even pay back what you owe and you wanna borrow more?",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "tatsu",
      "expression": "normal",
      "text": "...Fine. But the interest doubles. If you can't pay next time... you know what happens, right?",
      "characterImage": "tatsu/tatsu.png"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Tatsu pulls out a wad of bills from her chest pocket. As she leans forward, I can see her cleavage...)"
    },
    {
      "character": "tatsu",
      "expression": "normal",
      "text": "Here, 100,000. That brings your debt to 600,000.",
