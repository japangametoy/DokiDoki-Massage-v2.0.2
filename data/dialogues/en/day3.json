      "character": "player",
      "expression": "alert",
      "text": "T-Tatsu...!",
      "hideCharacter": true
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Shit... it's Tatsu the loan shark. She's here to collect on the money I borrowed last month...)"
    },
    {
      "character": "player",
      "hideCharacter": true,
      "text": "(Still, those are some incredible breasts... If they're that big, her shoulders must be killing her...)"
    },
    {
      "character": "tatsu",
      "expression": "normal",
      "text": "What's with that face? You don't look too happy to see a customer.",
